// Prisma schema – MySQL
// https://pris.ly/d/mysql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Permissao {
  DEV
  ADM
  TEC
  USR
}

enum Layout {
  MOVEL
  FIXO
}

model Coordenadoria {
  id           String    @id @default(uuid())
  nome         String    @db.VarChar(120)
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @default(now()) @updatedAt

  usuarios Usuario[]
  reservas Reserva[]

  @@map("coordenadorias")
}

model Usuario {
  id              String    @id @default(uuid())
  nome            String
  nomeSocial      String?
  login           String    @unique
  email           String    @unique
  permissao       Permissao @default(USR)
  status          Boolean   @default(true)
  avatar          String?   @db.Text
  coordenadoriaId String?

  ultimoLogin   DateTime  @default(now())
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @default(now()) @updatedAt

  coordenadoria Coordenadoria?   @relation(fields: [coordenadoriaId], references: [id], onDelete: SetNull)
  reservas      Reserva[]
  participacoes ReservaParticipante[]

  @@map("usuarios")
}

model Sala {
  id           String    @id @default(uuid())
  nome         String    @db.VarChar(120)
  andar        String?   @db.VarChar(60)
  numero       String?   @db.VarChar(10)
  lotacao      Int?
  layout       Layout?
  /// Caminho público da foto do layout (ex.: /uploads/salas/...). Usado quando layout = MOVEL.
  layoutImagemUrl String? @db.VarChar(512)
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @default(now()) @updatedAt

  reservas     Reserva[]
  mobiliarios  SalaMobiliario[]
  midias       SalaMidia[]

  @@map("salas")
}

model SalaMobiliario {
  id         String   @id @default(uuid())
  salaId      String
  nome        String   @db.VarChar(120)
  quantidade  Int
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt

  sala Sala @relation(fields: [salaId], references: [id], onDelete: Cascade)

  @@map("sala_mobiliarios")
}

model SalaMidia {
  id         String   @id @default(uuid())
  salaId      String
  nome        String   @db.VarChar(120)
  quantidade  Int
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @default(now()) @updatedAt

  sala Sala @relation(fields: [salaId], references: [id], onDelete: Cascade)

  @@map("sala_midias")
}

model Reserva {
  id               String   @id @default(uuid())
  salaId           String
  usuarioId        String?
  usuarioLogin     String   @db.VarChar(60)
  /// Nome do responsável pela reserva (preenchido no formulário).
  usuarioNome      String?  @db.VarChar(255)
  coordenadoriaId  String?
  inicio           DateTime
  fim              DateTime
  titulo           String?  @db.VarChar(255)
  telefoneRamal    String?  @db.VarChar(80)
  emailContato     String?  @db.VarChar(255)
  numeroParticipantes Int?
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @default(now()) @updatedAt

  sala           Sala                   @relation(fields: [salaId], references: [id], onDelete: Cascade)
  usuario        Usuario?               @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  coordenadoria  Coordenadoria?         @relation(fields: [coordenadoriaId], references: [id], onDelete: SetNull)
  participantes  ReservaParticipante[]

  @@map("reservas")
}

model ReservaParticipante {
  id         String   @id @default(uuid())
  reservaId  String
  usuarioId  String
  criadoEm   DateTime @default(now())

  reserva Reserva @relation(fields: [reservaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([reservaId, usuarioId])
  @@map("reserva_participantes")
}
