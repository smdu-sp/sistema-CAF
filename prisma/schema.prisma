// Prisma schema – MySQL
// https://pris.ly/d/mysql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Permissao {
  DEV
  ADM
  TEC
  USR
}

model Coordenadoria {
  id           String    @id @default(uuid())
  nome         String    @db.VarChar(120)
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @default(now()) @updatedAt

  usuarios Usuario[]
  reservas Reserva[]

  @@map("coordenadorias")
}

model Usuario {
  id              String    @id @default(uuid())
  nome            String
  nomeSocial      String?
  login           String    @unique
  email           String    @unique
  permissao       Permissao @default(USR)
  status          Boolean   @default(true)
  avatar          String?   @db.Text
  coordenadoriaId String?

  ultimoLogin   DateTime  @default(now())
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @default(now()) @updatedAt

  coordenadoria Coordenadoria?   @relation(fields: [coordenadoriaId], references: [id], onDelete: SetNull)
  reservas      Reserva[]
  participacoes ReservaParticipante[]

  @@map("usuarios")
}

model Sala {
  id           String    @id @default(uuid())
  nome         String    @db.VarChar(120)
  andar        String?   @db.VarChar(60)
  localizacao  String?   @db.VarChar(255)
  descricao    String?   @db.Text
  capacidade   Int?
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @default(now()) @updatedAt

  reservas Reserva[]

  @@map("salas")
}

model Reserva {
  id               String   @id @default(uuid())
  salaId           String
  usuarioId        String?
  usuarioLogin     String   @db.VarChar(60)
  usuarioNome      String?  @db.VarChar(255)
  coordenadoriaId  String?
  inicio           DateTime
  fim              DateTime
  titulo           String?  @db.VarChar(255)
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @default(now()) @updatedAt

  sala           Sala                   @relation(fields: [salaId], references: [id], onDelete: Cascade)
  usuario        Usuario?               @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  coordenadoria  Coordenadoria?         @relation(fields: [coordenadoriaId], references: [id], onDelete: SetNull)
  participantes  ReservaParticipante[]

  @@map("reservas")
}

model ReservaParticipante {
  id         String   @id @default(uuid())
  reservaId  String
  usuarioId  String
  criadoEm   DateTime @default(now())

  reserva Reserva @relation(fields: [reservaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([reservaId, usuarioId])
  @@map("reserva_participantes")
}
