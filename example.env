# URL da API de auth/usuários (qualquer servidor compatível; não usa pasta base-backend)
NEXT_PUBLIC_API_URL=http://localhost:3000/

# Obrigatório para NextAuth. Use apenas em .env.local e um único valor.
# Se mudar o AUTH_SECRET ou tiver dois arquivos com valores diferentes, apague os cookies do site (localhost) ou faça logout.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# URL do app (dev: http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000
