enum Layout {
  MOVEL
  FIXO
}

model SalaReserva {
  id           String    @id @default(uuid())
  nome         String    @db.VarChar(120)
  andar        String?   @db.VarChar(60)
  numero       String?   @db.VarChar(10)
  lotacao      Int?
  layout       Layout?
  ativo        Boolean   @default(true)
  
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @default(now()) @updatedAt
 
  reservas     Reserva[]
 
  @@map("reserva_sala.salas")
}
 
model Reserva {
  id               String   @id @default(uuid())
  salaId           String
  usuarioId        String?
  usuarioLogin     String   @db.VarChar(60)
  usuarioNome      String?  @db.VarChar(255)
  coordenadoriaId  String?
  inicio           DateTime
  fim              DateTime
  titulo           String?  @db.VarChar(255)

  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @default(now()) @updatedAt
 
  sala           SalaReserva            @relation(fields: [salaId], references: [id], onDelete: Cascade)
  usuario        Usuario?               @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  coordenadoria  Coordenadoria?         @relation(fields: [coordenadoriaId], references: [id], onDelete: SetNull)
  participantes  ReservaParticipante[]
 
  @@map("reserva_sala.reservas")
}
 
model ReservaParticipante {
  id         String   @id @default(uuid())
  reservaId  String

  usuarioId  String
  criadoEm   DateTime @default(now())
 
  reserva Reserva @relation(fields: [reservaId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
 
  @@unique([reservaId, usuarioId])
  @@map("reserva_sala.reserva_participantes")
}